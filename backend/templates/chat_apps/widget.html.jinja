<!DOCTYPE html>
<html lang="en" data-bs-theme="{{ theme_mode }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Awesome Website</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <style>
        :root {
            --gradient-bg: linear-gradient(135deg, {{ gradient_colors | join(', ') }});
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bs-body-bg);
            margin: 0;
        }
        
        /* Widget Container */
        #widgetContainer { position: fixed; bottom: 20px; right: 20px; z-index: 1000; display: flex; flex-direction: column; align-items: flex-end; }
        
        #chatWindow {
            display: none; width: 360px; height: 550px; background-color: var(--bs-body-bg);
            border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.3); border: 1px solid var(--bs-border-color);
            flex-direction: column; margin-bottom: 15px; overflow: hidden; animation: slideUp 0.3s ease;
        }
        @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

        /* Toggle Button */
        #widgetToggle {
            width: 60px; height: 60px; border-radius: 50%; background: var(--gradient-bg); color: white;
            display: flex; align-items: center; justify-content: center; font-size: 1.8rem; cursor: pointer;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2); transition: transform 0.2s;
        }
        #widgetToggle:hover { transform: scale(1.05); }

        /* Header */
        .chat-header { background: var(--gradient-bg); color: white; padding: 1rem; display: flex; justify-content: space-between; align-items: center; }
        .chat-header h5 { margin: 0; font-size: 1.1rem; font-weight: bold; }

        /* Body */
        .chat-body { flex-grow: 1; padding: 1rem; overflow-y: auto; background-color: var(--bs-tertiary-bg); position: relative; }

        /* Views inside Widget */
        .w-view { display: none; height: 100%; flex-direction: column; justify-content: center; }
        .w-view.active { display: flex; }

        /* Message Bubbles */
        .message { margin-bottom: 1rem; display: flex; flex-direction: column; animation: fadeIn 0.3s; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        .msg-user { align-items: flex-end; }
        .msg-bot { align-items: flex-start; }
        .bubble { max-width: 85%; padding: 0.6rem 1rem; border-radius: 1rem; font-size: 0.9rem; line-height: 1.4; }
        .msg-user .bubble { background: var(--gradient-bg); color: white; border-bottom-right-radius: 0.2rem; }
        .msg-bot .bubble { background-color: var(--bs-body-bg); border: 1px solid var(--bs-border-color); border-bottom-left-radius: 0.2rem; }

        /* Footer Input */
        .chat-footer { padding: 0.8rem; background-color: var(--bs-body-bg); border-top: 1px solid var(--bs-border-color); display: flex; align-items: center; gap: 0.5rem; }
        .chat-footer input { flex-grow: 1; border: none; background: var(--bs-tertiary-bg); padding: 0.5rem 1rem; border-radius: 20px; font-size: 0.9rem; color: var(--bs-body-color); }
        .chat-footer input:focus { outline: none; }
        .btn-action { background: transparent; border: none; color: var(--bs-secondary-color); font-size: 1.1rem; }
        .btn-send { background: var(--gradient-bg); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-size: 1.2rem; }

        /* Dummy Site */
        .hero { height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; }
        .recording-pulse { animation: pulse 1.5s infinite; color: #dc3545 !important; }
        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.3); } 100% { transform: scale(1); } }
    </style>
</head>
<body>

    <div class="hero">
        <h1 class="display-3 fw-bold">Welcome to Our Service</h1>
        <p class="lead text-muted mt-3">We build amazing things. Have a question? Ask our AI assistant!</p>
        <button class="btn btn-outline-primary mt-4" style="border-radius: 50px;" onclick="toggleChat()">Contact Support</button>
    </div>

    <div id="widgetContainer">
        <div id="chatWindow">
            <div class="chat-header">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-robot fs-4"></i><h5>AI Support</h5>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn-close btn-close-white" id="btnLogout" style="display:none;" onclick="logout()" title="Logout"></button>
                    <button class="btn-close btn-close-white" onclick="toggleChat()"></button>
                </div>
            </div>
            
            <div class="chat-body">
                <!-- Login View -->
                <div id="w-login" class="w-view active text-center">
                    <h5 class="fw-bold mb-3">Sign In to Chat</h5>
                    <input type="text" id="wUsername" class="form-control mb-2" placeholder="Username">
                    <input type="password" id="wPassword" class="form-control mb-3" placeholder="Password">
                    <button class="btn w-100 text-white fw-bold mb-2" style="background: var(--gradient-bg)" onclick="handleAuth('login')">Login</button>
                    <button class="btn btn-outline-secondary w-100" onclick="handleAuth('register')">Create Account</button>
                </div>

                <!-- Chat View -->
                <div id="w-chat" class="w-view" style="justify-content: flex-start; height: auto;">
                    <div id="chatMessages"></div>
                </div>
            </div>
            
            <!-- Footer (Hidden in Login) -->
            <div class="chat-footer" id="chatFooter" style="display:none;">
                <input type="file" id="fileInput" class="d-none" onchange="handleFileSelect(event)">
                <button class="btn-action" title="Attach" onclick="document.getElementById('fileInput').click()"><i class="bi bi-paperclip"></i></button>
                <button class="btn-action" id="recordBtn" title="Voice" onclick="toggleRecording()"><i class="bi bi-mic"></i></button>
                <input type="text" id="messageInput" placeholder="Type a message...">
                <button class="btn-action btn-send" onclick="sendMessage()"><i class="bi bi-send-fill"></i></button>
            </div>
        </div>

        <div id="widgetToggle" onclick="toggleChat()"><i class="bi bi-chat-dots-fill"></i></div>
    </div>

<script>
    let isChatOpen = false;
    let token = localStorage.getItem('ai_widget_token');

    function toggleChat() {
        const win = document.getElementById('chatWindow');
        const icon = document.getElementById('widgetToggle').querySelector('i');
        isChatOpen = !isChatOpen;
        win.style.display = isChatOpen ? 'flex' : 'none';
        icon.className = isChatOpen ? 'bi bi-x-lg' : 'bi bi-chat-dots-fill';
        if (isChatOpen) checkAuth();
    }

    function checkAuth() {
        if (token) {
            document.getElementById('w-login').classList.remove('active');
            document.getElementById('w-chat').classList.add('active');
            document.getElementById('chatFooter').style.display = 'flex';
            document.getElementById('btnLogout').style.display = 'block';
            loadHistory();
        } else {
            document.getElementById('w-login').classList.add('active');
            document.getElementById('w-chat').classList.remove('active');
            document.getElementById('chatFooter').style.display = 'none';
            document.getElementById('btnLogout').style.display = 'none';
        }
    }

    function logout() {
        localStorage.removeItem('ai_widget_token');
        token = null;
        document.getElementById('chatMessages').innerHTML = '';
        checkAuth();
    }

    {% if is_preview %}
    async function handleAuth(type) {
        token = "preview_token";
        localStorage.setItem('ai_widget_token', token);
        checkAuth();
    }

    async function loadHistory() {
        const container = document.getElementById('chatMessages');
        container.innerHTML = `<div class="text-center text-muted small my-3">Welcome to the Live Preview!</div>`;
        appendMessage('bot', 'This is a simulated preview. The backend is not connected.');
    }

    async function sendMessage() {
        const text = input.value.trim();
        if (!text && !currentFile) return;
        appendMessage('user', text || `[Attached: ${currentFile.name}]`);
        input.value = ''; input.placeholder = "Type a message...";
        currentFile = null;

        const c = document.getElementById('chatMessages');
        const typing = document.createElement('div');
        typing.className = 'message msg-bot';
        typing.innerHTML = `<div class="bubble text-muted"><span class="spinner-grow spinner-grow-sm"></span></div>`;
        c.appendChild(typing);
        document.querySelector('.chat-body').scrollTop = document.querySelector('.chat-body').scrollHeight;

        setTimeout(() => {
            c.removeChild(typing);
            appendMessage('bot', `Simulated response. Export the app to talk to your AI!`);
        }, 1000);
    }
    {% else %}
    async function handleAuth(type) {
        const u = document.getElementById('wUsername').value;
        const p = document.getElementById('wPassword').value;
        if (!u || !p) return alert("Enter credentials");
        try {
            const res = await fetch(`/api/auth/${type}`, {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username: u, password: p })
            });
            const data = await res.json();
            if (res.ok) {
                token = data.access_token;
                localStorage.setItem('ai_widget_token', token);
                checkAuth();
            } else { alert(data.detail); }
        } catch (e) { alert("Auth failed"); }
    }

    async function loadHistory() {
        try {
            const res = await fetch('/api/history', { headers: { 'Authorization': `Bearer ${token}` }});
            if (res.status === 401) { logout(); return; }
            const data = await res.json();
            const container = document.getElementById('chatMessages');
            container.innerHTML = '';
            if (data.history && data.history.length > 0) {
                data.history.forEach(m => appendMessage(m.role, m.content));
            } else {
                container.innerHTML = `<div class="text-center text-muted small my-3">Start a conversation</div>`;
            }
        } catch (e) {}
    }
    {% endif %}

    // Chat Logic
    let currentFile = null;
    let mediaRecorder = null;
    let audioChunks = [];
    let isRecording = false;

    const input = document.getElementById('messageInput');
    input.addEventListener('keypress', e => { if (e.key === 'Enter') sendMessage(); });

    function handleFileSelect(e) { currentFile = e.target.files[0]; if (currentFile) input.placeholder = `Attached: ${currentFile.name}`; }

    async function toggleRecording() {
        const btn = document.getElementById('recordBtn');
        const icon = btn.querySelector('i');
        if (!isRecording) {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                mediaRecorder = new MediaRecorder(stream);
                mediaRecorder.ondataavailable = e => audioChunks.push(e.data);
                mediaRecorder.onstop = () => {
                    const blob = new Blob(audioChunks, { type: 'audio/webm' });
                    currentFile = new File([blob], "rec.webm", { type: 'audio/webm' });
                    input.placeholder = "Voice recorded";
                    stream.getTracks().forEach(t => t.stop());
                };
                audioChunks = [];
                mediaRecorder.start();
                isRecording = true;
                btn.classList.add('recording-pulse');
                icon.className = 'bi bi-stop-fill';
            } catch (err) {}
        } else {
            mediaRecorder.stop();
            isRecording = false;
            btn.classList.remove('recording-pulse');
            icon.className = 'bi bi-mic';
        }
    }

    function playTTS(text) {
        if ('speechSynthesis' in window) {
            window.speechSynthesis.speak(new SpeechSynthesisUtterance(text.replace(/[*#_`]/g, '')));
        }
    }

    function appendMessage(role, content) {
        const c = document.getElementById('chatMessages');
        const div = document.createElement('div');
        div.className = `message ${role === 'user' ? 'msg-user' : 'msg-bot'}`;
        let tts = role === 'bot' ? `<div class="text-start mt-1"><button class="btn btn-sm btn-link text-muted p-0" style="font-size:0.75rem;" onclick="playTTS(this.dataset.text)" data-text="${content.replace(/"/g, '&quot;')}"><i class="bi bi-volume-up"></i></button></div>` : '';
        
        let fmt = role === 'bot' ? marked.parse(content) : content.replace(/\n/g, '<br>');
        
        div.innerHTML = `<div class="bubble">${fmt}${tts}</div>`;
        c.appendChild(div);
        document.querySelector('.chat-body').scrollTop = document.querySelector('.chat-body').scrollHeight;
    }

    {% if not is_preview %}
    async function sendMessage() {
        const text = input.value.trim();
        if (!text && !currentFile) return;
        appendMessage('user', text || `[Attached: ${currentFile.name}]`);
        input.value = ''; input.placeholder = "Type a message...";
        
        const fd = new FormData();
        if (text) fd.append('text', text);
        if (currentFile) {
            if (currentFile.type.startsWith('audio/')) fd.append('audio', currentFile);
            else fd.append('image', currentFile);
        }
        currentFile = null;

        const c = document.getElementById('chatMessages');
        const typing = document.createElement('div');
        typing.className = 'message msg-bot';
        typing.innerHTML = `<div class="bubble text-muted"><span class="spinner-grow spinner-grow-sm"></span></div>`;
        c.appendChild(typing);
        document.querySelector('.chat-body').scrollTop = document.querySelector('.chat-body').scrollHeight;

        try {
            const res = await fetch('/api/chat', { method: 'POST', headers: { 'Authorization': `Bearer ${token}` }, body: fd });
            const data = await res.json();
            c.removeChild(typing);
            if (res.status === 401) { logout(); return; }
            if (data.status === 'success') {
                const bRes = typeof data.response === 'string' ? data.response : JSON.stringify(data.response);
                appendMessage('bot', bRes);
            } else { appendMessage('bot', `Error: ${data.message}`); }
        } catch (err) {
            c.removeChild(typing);
            appendMessage('bot', 'Error');
        }
    }
    {% endif %}
</script>
</body>
</html>
